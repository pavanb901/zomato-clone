pipeline {
    agent any

    environment {
        DOCKER_CREDENTIALS = credentials('docker-hub-credentials')
        DOCKER_IMAGE = "${DOCKER_CREDENTIALS_USR}/zomato-clone"
        DOCKER_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                echo "Checking out source code..."
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                echo "Installing dependencies..."
                sh 'docker run --rm -v "$WORKSPACE":/app -w /app node:18-alpine npm ci'
            }
        }

        stage('Lint') {
            steps {
                echo "Running linter..."
                sh 'docker run --rm -v "$WORKSPACE":/app -w /app node:18-alpine npm run lint || true'
            }
        }

        stage('Build') {
            steps {
                echo "Building React app..."
                sh 'docker run --rm -v "$WORKSPACE":/app -w /app -e NODE_OPTIONS=--openssl-legacy-provider node:18-alpine npm run build'
            }
        }

        stage('Docker Build') {
            steps {
                echo "Building Docker image..."
                sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                sh "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest"
            }
        }

        stage('Docker Push') {
            steps {
                echo "Pushing Docker image to Docker Hub..."
                sh "echo ${DOCKER_CREDENTIALS_PSW} | docker login -u ${DOCKER_CREDENTIALS_USR} --password-stdin"
                sh "docker push ${DOCKER_IMAGE}:${DOCKER_TAG}"
                sh "docker push ${DOCKER_IMAGE}:latest"
            }
        }

        stage('Deploy') {
            steps {
                echo "Deploying container..."
                sh """
                    docker stop zomato-clone-app || true
                    docker rm zomato-clone-app || true
                    docker run -d \
                        --name zomato-clone-app \
                        -p 3000:3000 \
                        --restart unless-stopped \
                        ${DOCKER_IMAGE}:${DOCKER_TAG}
                """
            }
        }
    }

    post {
        always {
            sh 'docker logout || true'
        }
        success {
            echo "Pipeline completed successfully! App running on port 3000."
        }
        failure {
            echo "Pipeline failed! Check the logs above for details."
        }
        cleanup {
            sh 'docker image prune -f || true'
        }
    }
}
